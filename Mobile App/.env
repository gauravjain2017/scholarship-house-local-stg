# Copy to .env and fill in. These are read by app.config.ts at build/start time.
APP_ENV=development


# Per-environment API base URLs (no trailing slash)

API_URL_DEV=http://192.168.1.14:3000

API_URL_STAGING=https://staging.api.your-domain.com
API_URL_PROD=https://api.your-domain.com


# EAS project id (run `eas init` once to populate)
EAS_PROJECT_ID=


