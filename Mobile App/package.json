{
  "name": "property-submitter-mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:dev": "cross-env APP_ENV=development expo start",
    "start:staging": "cross-env APP_ENV=staging expo start",
    "start:prod": "cross-env APP_ENV=production expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "build:ios:dev": "eas build --platform ios --profile development",
    "build:ios:staging": "eas build --platform ios --profile staging",
    "build:ios:prod": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "expo": "^54.0.0",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.23.8"
